{#
| Variable         | Type    | Description                     |
|------------------|---------|---------------------------------|
| cart             | object  |                                 |
| cart.items_count | int     |                                 |
| cart.total       | string  | Formatted total ex: "١٠٠ ر.س"   |
#}
{% set important_links = theme.settings.get('important_links') %}
{% set is_home = is_page('index') %}

<header class="store-header {{ is_home ? 'is-transparent' : 'is-solid' }}">
  {# 
    TAJ ALAMEERA: We removed the bulky top-navbar to match the minimal WP design.
    The Gold Ticker (injected via JS) takes its place seamlessly. 
  #}

  {# Main Nav #}
  <div id="mainnav" class="main-nav-container flex items-center transition-all duration-500 w-full">
      <div class="inner bg-inherit w-full">
          <div class="container">
              <div class="flex items-center justify-between relative h-20">
                  
                  {# Right Side: Navigation Links & Mobile Burger #}
                  <div class="flex items-center flex-1">
                      <a class="lg:hidden mburger mburger--collapse leading-none rtl:ml-4 ltr:mr-4" href="#mobile-menu" aria-label="Open-menu">
                        <i class="sicon-menu text-2xl" style="color: var(--brand-gold);"></i>
                      </a>
                      
                      {# Native Salla Menu: Will dynamically load your Dashboard categories #}
                      <div class="hidden lg:block taj-main-menu">
                          <custom-main-menu></custom-main-menu>
                      </div>
                  </div>

                  {# Center: Centered Logo #}
                  <div class="flex-shrink-0 absolute left-1/2 transform -translate-x-1/2">
                      <a class="navbar-brand flex items-center justify-center" href="{{ store.url }}">
                          <img fetchpriority="high" style="max-height: 65px; width: auto;" loading="eager" src="{{ store.logo|cdn(175) }}" alt="{{ store.name }} logo">
                          {% if is_home %}
                            <h1 class="sr-only">{{ store.name }}</h1>
                          {% else %}
                            <h2 class="sr-only">{{ store.name }}</h2>
                          {% endif %}
                      </a>
                  </div>

                  {# Left Side: Icons (Cart, User, Search) #}
                  <div class="flex items-center justify-end flex-1 gap-5 my-2.5">
                      
                      {# Search Trigger #}
                      <button onclick="salla.event.dispatch('search::open')" class="hover:-translate-y-1 transition-transform" style="color: var(--brand-gold);" aria-label="Search">
                          <i class="sicon-search text-xl"></i>
                      </button>

                      {# User Menu #}
                      <salla-user-menu avatar-only show-header show-trigger style="color: var(--brand-gold);"></salla-user-menu>
                      
                      {# Cart #}
                      <salla-cart-summary class="hover:-translate-y-1 transition-transform" style="color: var(--brand-gold);">
                        <i slot="icon" class="header-btn__icon icon sicon-shopping-bag text-xl"></i>
                      </salla-cart-summary>
                  </div>
                  
              </div>
          </div>
      </div>
  </div>
</header>

<style>
    /* TAJ ALAMEERA HEADER LOGIC */
    .store-header {
        width: 100%;
        z-index: 999;
        transition: background-color 0.4s ease, box-shadow 0.4s ease;
    }

    /* Homepage Transparent State */
    .store-header.is-transparent {
        position: absolute;
        top: 0; /* Sits right under the ticker */
        background: transparent;
        box-shadow: none;
    }

    /* Inner Pages Solid State */
    .store-header.is-solid {
        position: relative;
        background: var(--soft-cream);
        border-bottom: 1px solid var(--border-hex);
    }

    /* Sticky State (When user scrolls down) - Reusing Salla's .fixed-header class */
    .fixed-header .store-header.is-transparent {
        position: fixed;
        top: 46px; /* Below the Gold Ticker */
        background: rgba(249, 247, 242, 0.95); /* Soft Cream Frosted Glass */
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        border-bottom: 1px solid var(--border-hex);
    }

    /* Style Salla's Native Menu to match WordPress */
    .taj-main-menu {
        font-family: 'Almarai', sans-serif;
        font-weight: 700;
    }
    
    /* Target the text inside the Salla web component */
    custom-main-menu::part(link) {
        color: var(--brand-gold);
        transition: color 0.3s;
        font-size: 15px;
    }
    
    custom-main-menu::part(link):hover {
        color: var(--brand-dark);
    }

    @media (max-width: 768px) {
        .fixed-header .store-header.is-transparent {
            top: 40px; /* Mobile Ticker Height */
        }
    }
</style>